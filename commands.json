{
  "commands": [
    {
      "id": "ade.create-view",
      "label": "Create ADE View",
      "workflow": "ade",
      "order": 10,
      "template": "ade createview view={{view}} branch={{branch}} txn={{txn}}",
      "parameters": [
        { "name": "view", "label": "View name", "required": true, "pattern": "^[A-Za-z0-9_.-]+$" },
        { "name": "branch", "label": "Branch", "required": false, "pattern": "^[A-Za-z0-9_.-]+$" },
        { "name": "txn", "label": "Transaction", "required": false, "pattern": "^[A-Za-z0-9_.-]+$" }
      ]
    },
    {
      "id": "ade.use-view",
      "label": "Enter ADE View",
      "workflow": "ade",
      "order": 20,
      "template": "ade useview view={{view}}",
      "parameters": [
        { "name": "view", "label": "View name", "required": true, "pattern": "^[A-Za-z0-9_.-]+$" }
      ]
    },
    {
      "id": "ade.begintrans",
      "label": "Create Transaction",
      "workflow": "ade",
      "order": 30,
      "template": "ade begintrans view={{view}} txn={{txn}}",
      "parameters": [
        { "name": "view", "label": "View name", "required": true, "pattern": "^[A-Za-z0-9_.-]+$" },
        { "name": "txn", "label": "Transaction", "required": true, "pattern": "^[A-Za-z0-9_.-]+$" }
      ]
    },
    {
      "id": "ade.status",
      "label": "View Status",
      "workflow": "ade",
      "order": 40,
      "template": "ade status view={{view}}",
      "parameters": [
        { "name": "view", "label": "View name", "required": true, "pattern": "^[A-Za-z0-9_.-]+$" }
      ]
    },
    {
      "id": "ade.refresh-view",
      "label": "Refresh View",
      "workflow": "ade",
      "order": 50,
      "template": "ade refreshview view={{view}} branch={{branch}}",
      "parameters": [
        { "name": "view", "label": "View name", "required": true, "pattern": "^[A-Za-z0-9_.-]+$" },
        { "name": "branch", "label": "Branch", "required": false, "pattern": "^[A-Za-z0-9_.-]+$" }
      ]
    },
    {
      "id": "ade.checkin-save",
      "label": "Check In And Save",
      "workflow": "ade",
      "order": 60,
      "template": "ade checkin-save view={{view}} txn={{txn}}",
      "parameters": [
        { "name": "view", "label": "View name", "required": true, "pattern": "^[A-Za-z0-9_.-]+$" },
        { "name": "txn", "label": "Transaction", "required": false, "pattern": "^[A-Za-z0-9_.-]+$" }
      ]
    },
    {
      "id": "orareview.create",
      "label": "Create OraReview",
      "workflow": "ade",
      "order": 70,
      "template": "orareview create view={{view}} bug={{bug}} reviewers={{reviewers}}",
      "skill": "orareview",
      "mcp": "orareview",
      "instructions": [
        "Use the orareview skill for upload/update workflow and required preflight checks.",
        "Use OraReview MCP tools for read-only review metadata, reviewer status, comments, and merge-check details when helpful."
      ],
      "parameters": [
        { "name": "view", "label": "View name", "required": true, "pattern": "^[A-Za-z0-9_.-]+$" },
        { "name": "bug", "label": "Bug number", "required": true, "pattern": "^[0-9]+$" },
        { "name": "reviewers", "label": "Reviewers", "required": false, "pattern": "^[A-Za-z0-9_.@,+-]+$" }
      ]
    },
    {
      "id": "mergereq.submit",
      "label": "Submit Merge Request",
      "workflow": "ade",
      "order": 80,
      "template": "mergereq submit view={{view}} bug={{bug}} mode={{mode}} manager={{manager}} release={{release}} cc={{cc}}",
      "skill": "mergereq",
      "mcp": "mergereq",
      "instructions": [
        "Use the mergereq skill for submission workflow, property checks, and command generation.",
        "Use Mergereq MCP tools for report-card details and current-transaction quality previews before submitting when available."
      ],
      "parameters": [
        { "name": "view", "label": "View name", "required": true, "pattern": "^[A-Za-z0-9_.-]+$" },
        { "name": "bug", "label": "Bug number", "required": true, "pattern": "^[0-9]+$" },
        { "name": "mode", "label": "Mode", "required": true, "default": "check", "options": ["check", "submit", "db-only", "no-mail"] },
        { "name": "manager", "label": "Manager email", "required": false, "pattern": "^[A-Za-z0-9_.@+-]+$" },
        { "name": "release", "label": "Release email", "required": false, "pattern": "^[A-Za-z0-9_.@+-]+$" },
        { "name": "cc", "label": "CC emails", "required": false, "pattern": "^[A-Za-z0-9_.@,+-]+$" }
      ]
    },
    {
      "id": "codesearch.search",
      "label": "CodeSearch",
      "workflows": ["ade", "custom"],
      "order": 90,
      "template": "codesearch search query={{query}} full={{full}} definition={{definition}} symbol={{symbol}} path={{path}} type={{type}} ade_label={{ade_label}} ade_label_series={{ade_label_series}}",
      "mcp": "codesearch",
      "instructions": [
        "Use the CodeSearch MCP search tool for ADE/OpenGrok searches and summarize contextual snippets.",
        "Provide ade_label or ade_label_series when not running inside the target ADE view.",
        "Map query to the most appropriate CodeSearch field, usually full unless symbol or definition is more specific."
      ],
      "parameters": [
        { "name": "query", "label": "Search query", "required": false, "pattern": "^[A-Za-z0-9_ ./,:@+=()#*\\n-]+$" },
        { "name": "full", "label": "Full text", "required": false, "pattern": "^[A-Za-z0-9_ ./,:@+=()#*\\n-]+$" },
        { "name": "definition", "label": "Definition", "required": false, "pattern": "^[A-Za-z0-9_.:@+=#*-]+$" },
        { "name": "symbol", "label": "Symbol", "required": false, "pattern": "^[A-Za-z0-9_.:@+=#*-]+$" },
        { "name": "path", "label": "Path", "required": false, "pattern": "^[A-Za-z0-9_./:@+=*,-]+$" },
        { "name": "type", "label": "File type", "required": false, "pattern": "^[A-Za-z0-9_,.+-]+$" },
        { "name": "ade_label", "label": "ADE label", "required": false, "pattern": "^[A-Za-z0-9_.-]+$" },
        { "name": "ade_label_series", "label": "ADE label series", "required": false, "pattern": "^[A-Za-z0-9_.-]+$" }
      ]
    },
    {
      "id": "project.inspect",
      "label": "Inspect Selected Project",
      "workflows": ["project", "custom"],
      "order": 110,
      "template": "inspect selected project focus={{focus}}",
      "parameters": [
        { "name": "focus", "label": "Focus", "required": false, "pattern": "^[A-Za-z0-9_ ./,:@+=-]+$" }
      ]
    },
    {
      "id": "project.run-tests",
      "label": "Run Project Tests",
      "workflows": ["project", "custom"],
      "order": 120,
      "template": "run project tests command={{test_command}}",
      "parameters": [
        { "name": "test_command", "label": "Test command", "required": false, "pattern": "^[A-Za-z0-9_ ./,:@+=-]+$" }
      ]
    }
  ]
}
